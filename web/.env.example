# ============================================================
# REQUIRED — without these the lead form has nowhere to send
# submissions (n8n has been retired in favor of this pipeline).
# ============================================================

# Supabase project (Settings -> API in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, never exposed to the client. Keep this out of NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot for lead notifications (message @BotFather to create one,
# then message your bot once and check
# https://api.telegram.org/bot<token>/getUpdates to find your chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Canonical site URL, used for metadata/OG/sitemap/hreflang. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://infobackground.example

# Comma-separated list of origins allowed to call POST /api/lead — the
# cross-origin endpoint the legacy static index.html form posts to (this
# app's own form uses the Server Action instead and isn't affected by
# this). Defaults to https://infobackground.com,https://www.infobackground.com
# plus localhost:8000 for local static-file testing if left unset. Set
# this explicitly once the static site's real domain is known.
LEAD_CORS_ORIGIN=

# ============================================================
# OPTIONAL — the site builds and runs fully without any of these.
# Each one only loads/activates when its variable is set; leaving
# them empty means zero third-party requests and zero console
# errors (verify this before shipping analytics for real).
# ============================================================

# Analytics & marketing (spec section 2). NEXT_PUBLIC_GTM_ID and
# NEXT_PUBLIC_GA_ID are mutually-exclusive in practice: if your GTM
# container also fires a GA4 tag, setting both double-counts events.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Spam protection beyond the built-in honeypot field.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Real distributed rate limiting (Upstash Redis REST API). Without
# these, the lead action falls back to an in-memory counter that is
# NOT meaningful protection in a serverless/multi-instance production
# deploy — set these for real, or rely on Vercel's platform-level
# Firewall/Rate-Limiting rules instead (dashboard config, no code).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Vercel sets these automatically in its own environment — you
# don't need to set them yourself, they're listed for reference.
# ============================================================
# VERCEL_ENV=production|preview|development
